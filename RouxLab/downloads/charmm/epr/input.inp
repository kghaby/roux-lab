* dynamics with r1
*

!read topology
open read card unit 1 name top_all27_prot_lipid.rtf
read rtf card unit 1

!stream R1 topology
stream top_r1.str

!read parameters
open read card unit 1 name par_all27_prot_lipid.prm
read param card unit 1

!stream R1 parameters
stream par_supl.str
stream par_r1.str
stream par_r1_cmap.str

